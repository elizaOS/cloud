# =============================================================================
# CLONE UR CRUSH - ENVIRONMENT VARIABLES
# =============================================================================
# Copy this to .env and fill in your actual values

# Eliza Cloud Integration (REQUIRED)
NEXT_PUBLIC_CLONEURCRUSH_ELIZA_URL=http://localhost:3000
CLONEURCRUSH_ELIZA_API_KEY=generated_using_cloud
BLOB_READ_WRITE_TOKEN
# =============================================================================
# Note: BLOB_READ_WRITE_TOKEN is automatically provided by Vercel
# when you connect Blob Storage in production. No need to set it here!
# =============================================================================
NEXT_PUBLIC_PRIVY_APP_ID=
NEXT_PUBLIC_PRIVY_CLIENT_ID=
PRIVY_APP_SECRET=