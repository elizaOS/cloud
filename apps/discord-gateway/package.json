{
  "name": "@elizaos/discord-gateway",
  "version": "1.0.0",
  "description": "Multi-tenant Discord gateway service for Eliza Cloud",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target node",
    "start": "bun run src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "discord.js": "^14.18.0",
    "hono": "^4.6.0",
    "@hono/node-server": "^1.13.0",
    "@upstash/redis": "^1.34.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}

