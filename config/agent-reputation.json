{
  "$schema": "./agent-reputation.schema.json",
  "_comment": "Agent Reputation Configuration for ERC-8004/A2A. Secrets should be in .env, not here.",

  "scoring": {
    "_comment": "Reputation score formula: base + (positiveFactors) - (negativeFactors)",
    "baseScore": 50,
    "minScore": 0,
    "maxScore": 100,

    "positiveFactors": {
      "paymentDeposit": {
        "_comment": "Points per $1 deposited (capped at maxPoints)",
        "pointsPerDollar": 0.5,
        "maxPoints": 25
      },
      "successfulRequest": {
        "_comment": "Points per successful API request (capped at maxPoints)",
        "pointsPerRequest": 0.01,
        "maxPoints": 15
      },
      "accountAge": {
        "_comment": "Points per day of account age (capped at maxPoints)",
        "pointsPerDay": 0.1,
        "maxPoints": 10
      }
    },

    "negativeFactors": {
      "csamViolation": {
        "_comment": "Immediate zero score + ban",
        "pointsDeducted": 100,
        "autoban": true,
        "permanent": true
      },
      "selfHarmViolation": {
        "_comment": "Severe penalty",
        "pointsDeducted": 50,
        "autoban": false
      },
      "spamViolation": {
        "pointsDeducted": 10,
        "autoban": false
      },
      "scamViolation": {
        "pointsDeducted": 100,
        "autoban": true,
        "permanent": true
      },
      "harassmentViolation": {
        "pointsDeducted": 30,
        "autoban": false
      },
      "failedRequest": {
        "_comment": "Points per failed request (abuse indicator)",
        "pointsPerRequest": 0.1,
        "maxPoints": 10
      },
      "adminFlag": {
        "_comment": "Admin-imposed penalty (configurable per flag)",
        "defaultPoints": 20,
        "autoban": false
      }
    }
  },

  "trustLevels": {
    "_comment": "Trust levels based on reputation score",
    "untrusted": {
      "minScore": 0,
      "maxScore": 20,
      "rateLimit": 10,
      "maxRequestsPerMinute": 5
    },
    "low": {
      "minScore": 20,
      "maxScore": 40,
      "rateLimit": 30,
      "maxRequestsPerMinute": 20
    },
    "neutral": {
      "minScore": 40,
      "maxScore": 60,
      "rateLimit": 60,
      "maxRequestsPerMinute": 50
    },
    "trusted": {
      "minScore": 60,
      "maxScore": 80,
      "rateLimit": 100,
      "maxRequestsPerMinute": 100
    },
    "verified": {
      "minScore": 80,
      "maxScore": 100,
      "rateLimit": 200,
      "maxRequestsPerMinute": 200
    }
  },

  "moderation": {
    "_comment": "Moderation thresholds for OpenAI API",
    "criticalCategories": [
      "sexual/minors",
      "self-harm",
      "self-harm/intent",
      "self-harm/instructions"
    ],
    "thresholds": {
      "sexual/minors": 0.001,
      "self-harm": 0.5,
      "self-harm/intent": 0.5,
      "self-harm/instructions": 0.5
    },
    "violationsBeforeWarning": 1,
    "violationsBeforeRestriction": 3,
    "violationsBeforeBan": 5
  },

  "onChainSync": {
    "_comment": "Settings for syncing reputation to ERC-8004 ReputationRegistry",
    "enabled": true,
    "syncIntervalMinutes": 60,
    "minScoreChangeToSync": 5,
    "networks": ["base-sepolia", "base"]
  },

  "defaults": {
    "newAgentScore": 50,
    "newAgentTrustLevel": "neutral",
    "banDurationDays": 30,
    "permanentBanThreshold": 2
  }
}
