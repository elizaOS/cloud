{
  "name": "eliza-cloud-v2",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "find node_modules -path '*/thread-stream/test' -type d -exec rm -rf {} + 2>/dev/null || true; find node_modules -path '*/thread-stream/bench.js' -delete 2>/dev/null || true; find node_modules -path '*/thread-stream/LICENSE' -delete 2>/dev/null || true; find node_modules -path '*/thread-stream/README.md' -delete 2>/dev/null || true",
    "setup": "bun run scripts/setup.ts",
    "setup:check": "bun run scripts/setup.ts --check",
    "setup:onchain": "bun run scripts/setup.ts --onchain",
    "dev": "bun run scripts/startup-checks.ts && next dev --turbopack",
    "dev:quick": "next dev --turbopack",
    "dev:erc8004": "bun run scripts/dev-erc8004.ts",
    "dev:x402": "bun run scripts/dev-x402.ts",
    "dev:all": "bun run db:miniapp:seed && concurrently -k --kill-signal SIGTERM -n cloud,miniapp -c blue,magenta \"bun run dev:quick\" \"cd miniapp && bun run dev\"",
    "dev:full": "bun run setup:check && bun run dev:all",
    "build": "next build",
    "start": "next start",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:ios": "tauri ios dev",
    "tauri:ios:build": "tauri ios build",
    "tauri:ios:init": "tauri ios init",
    "tauri:android": "tauri android dev",
    "tauri:android:build": "tauri android build",
    "tauri:android:init": "tauri android init",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check-types": "NODE_OPTIONS='--max-old-space-size=8192' tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:local:setup": "tsx scripts/setup-local-db-comprehensive.ts",
    "db:local:start": "docker-compose up -d",
    "db:local:stop": "docker-compose down",
    "db:local:clean": "docker-compose down -v && docker network prune -f",
    "db:local:logs": "docker-compose logs -f postgres",
    "db:local:seed": "tsx scripts/seed-local-dev.ts",
    "db:miniapp:seed": "tsx scripts/seed-miniapp-dev.ts",
    "seed:credit-packs": "tsx scripts/seed-credit-packs.ts",
    "stripe:webhook": "stripe listen --forward-to localhost:3000/api/stripe/webhook",
    "cron:auto-top-up": "tsx scripts/trigger-auto-top-up.ts",
    "billing:set-email": "tsx scripts/set-billing-email.ts",
    "bootstrapper:build": "cd bootstrapper && ./build.sh",
    "cache:clear": "tsx scripts/clear-cache.ts",
    "cache:health": "tsx scripts/cache-health-check.ts",
    "mcp:inspector": "bunx @modelcontextprotocol/inspector@latest",
    "onchain": "bun run scripts/erc8004-setup-all.ts",
    "onchain:register": "bun run scripts/register-eliza-cloud.ts",
    "onchain:verify": "bun run scripts/erc8004-verify-all.ts",
    "onchain:deploy:base": "cd docs/docs/erc-8004-contracts && npm run deploy:upgradeable:base",
    "anvil:start": "cd docs/docs/erc-8004-contracts && npm run local",
    "test": "bun test tests/unit tests/security tests/integration/comprehensive-api.test.ts tests/integration/erc8004-marketplace.test.ts tests/integration/payout-flow.test.ts tests/integration/payout-status.test.ts tests/integration/agent-budgets.test.ts tests/integration/agent-monetization.test.ts",
    "test:unit": "bun test tests/unit",
    "test:security": "bun test tests/security",
    "test:integration": "bun test tests/integration/comprehensive-api.test.ts tests/integration/erc8004-marketplace.test.ts tests/integration/payout-flow.test.ts tests/integration/payout-status.test.ts tests/integration/agent-budgets.test.ts tests/integration/agent-monetization.test.ts",
    "test:e2e": "bun test tests/integration/admin-moderation.test.ts tests/integration/public-agent-a2a.test.ts tests/integration/x402-payment.test.ts",
    "test:watch": "bun test --watch tests/unit tests/security",
    "test:playwright": "playwright test --config=tests/playwright.config.ts",
    "test:playwright:ui": "playwright test --config=tests/playwright.config.ts --project=chromium",
    "test:playwright:api": "playwright test --config=tests/playwright.config.ts --project=api",
    "test:playwright:pages": "playwright test all-pages --config=tests/playwright.config.ts --project=chromium",
    "test:playwright:miniapp": "playwright test miniapp --config=tests/playwright.config.ts --project=miniapp",
    "test:playwright:report": "playwright show-report tests/playwright/test-reports/html",
    "admin:promote": "bun run scripts/promote-admin.ts",
    "admin:list": "bun run scripts/promote-admin.ts --list",
    "admin:revoke": "bun run scripts/promote-admin.ts --revoke"
  },
