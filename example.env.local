# =============================================================================
# REQUIRED - Databases (Two Separate Databases)
# =============================================================================
# Platform Database - SaaS tables (users, credits, containers, etc.)
DATABASE_URL=postgresql://user:password@host:5432/eliza_platform

# Agent Database - ElizaOS tables (agents, memories, rooms, etc.)
# Can be same as DATABASE_URL (dev) or separate database (production)
AGENT_DATABASE_URL=postgresql://user:password@host:5432/eliza_agents

# For local development, you can use the same database:
# DATABASE_URL=postgresql://localhost:5432/eliza_dev
# AGENT_DATABASE_URL=postgresql://localhost:5432/eliza_dev

# =============================================================================
# REQUIRED - Authentication (Privy)
# =============================================================================
NEXT_PUBLIC_PRIVY_APP_ID=your_privy_app_id_here
PRIVY_APP_SECRET=your_privy_app_secret_here
PRIVY_WEBHOOK_SECRET=replace_with_strong_random_secret

# =============================================================================
# OPTIONAL - AI Services (at least one recommended)
# =============================================================================
OPENAI_API_KEY=sk-your_openai_key_here
AI_GATEWAY_API_KEY=your_ai_gateway_key_here
FAL_KEY=

# =============================================================================
# OPTIONAL - Vercel Blob Storage (for Gallery/Media features)
# =============================================================================
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_your_token_here

# =============================================================================
# OPTIONAL - Cloudflare (for Container Deployments via 'elizaos deploy')
# =============================================================================
# Note: CLOUDFLARE_ACCOUNT_ID and R2_ACCOUNT_ID are usually the same value
CLOUDFLARE_ACCOUNT_ID=your_32_character_account_id_here
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here

# R2 Storage Access (for artifact storage)
# Generate these from: Cloudflare Dashboard → R2 → Manage R2 API Tokens
R2_ACCESS_KEY_ID=your_r2_access_key_id_here
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key_here

# R2 Configuration (usually can use defaults)
R2_BUCKET_NAME=eliza-artifacts
R2_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com

# Bootstrapper Image (optional - for custom or versioned deployments)
# BOOTSTRAPPER_IMAGE_TAG=elizaos/bootstrapper:v1.0.0
# BOOTSTRAPPER_IMAGE_TAG=ghcr.io/your-org/bootstrapper:latest

# =============================================================================
# OPTIONAL - Stripe (for Payment Processing)
# =============================================================================
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=sk_test_or_sk_live_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_SMALL_PACK_PRICE_ID=
STRIPE_SMALL_PACK_PRODUCT_ID=
STRIPE_MEDIUM_PACK_PRICE_ID=
STRIPE_MEDIUM_PACK_PRODUCT_ID=
STRIPE_LARGE_PACK_PRICE_ID=
STRIPE_LARGE_PACK_PRODUCT_ID=

# =============================================================================
# REQUIRED for Production - Cron Security (for scheduled jobs)
# =============================================================================
# CRITICAL: CRON_SECRET is REQUIRED in production to prevent unauthorized access
# to cron endpoints (artifact cleanup, health checks, etc.)
# Without this, anyone can trigger resource-intensive operations or cause data loss
CRON_SECRET=random_secret_minimum_32_characters_here_generate_strong_secret

# =============================================================================
# APP Configuration
# =============================================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
