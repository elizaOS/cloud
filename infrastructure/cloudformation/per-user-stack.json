{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Description": "ElizaOS Per-User Container Stack - Production Ready - 1 t3.small instance with ECS + Monitoring",
  "Parameters": {
    "UserId": {
      "Type": "String",
      "Description": "Unique user ID for this deployment"
    },
    "UserEmail": {
      "Type": "String",
      "Description": "User email for tagging",
      "Default": "unknown@example.com"
    },
    "ContainerImage": {
      "Type": "String",
      "Description": "ECR image URI for the container"
    },
    "ContainerPort": {
      "Type": "Number",
      "Default": 3000,
      "Description": "Container port"
    },
    "ContainerCpu": {
      "Type": "Number",
      "Default": 1792,
      "Description": "CPU units (1792 = 1.75 vCPU, 87.5% of t3.small)"
    },
    "ContainerMemory": {
      "Type": "Number",
      "Default": 1792,
      "Description": "Memory in MB (1792 = 1.75 GB, 87.5% of t3.small)"
    },
    "SharedVPCId": {
      "Type": "String",
      "Description": "Shared VPC ID"
    },
    "SharedSubnetId": {
      "Type": "String",
      "Description": "Shared public subnet ID"
    },
    "SharedALBArn": {
      "Type": "String",
      "Description": "Shared ALB ARN"
    },
    "SharedListenerArn": {
      "Type": "String",
      "Description": "Shared ALB HTTPS Listener ARN"
    },
    "SharedALBSecurityGroupId": {
      "Type": "String",
      "Description": "Shared ALB Security Group ID"
    },
    "ECSExecutionRoleArn": {
      "Type": "String",
      "Description": "ECS Task Execution Role ARN"
    },
    "ECSTaskRoleArn": {
      "Type": "String",
      "Description": "ECS Task Role ARN"
    },
    "KeyName": {
      "Type": "String",
      "Description": "EC2 Key Pair for SSH access",
      "Default": ""
    },
    "ListenerRulePriority": {
      "Type": "Number",
      "Description": "ALB Listener Rule Priority (must be unique, 1-50000)",
      "MinValue": 1,
      "MaxValue": 50000
    },
    "SNSTopicArn": {
      "Type": "String",
      "Description": "SNS Topic ARN for alerts (optional)",
      "Default": ""
    }
  },
  "Conditions": {
    "HasKeyPair": {
      "Fn::Not": [{ "Fn::Equals": [{ "Ref": "KeyName" }, ""] }]
    },
    "HasSNSTopic": {
      "Fn::Not": [{ "Fn::Equals": [{ "Ref": "SNSTopicArn" }, ""] }]
    }
  },
  "Resources": {
    "UserSecurityGroup": {
      "Type": "AWS::EC2::SecurityGroup",
      "Properties": {
        "GroupName": {
          "Fn::Sub": "elizaos-user-${UserId}-sg"
        },
        "GroupDescription": {
          "Fn::Sub": "Security group for user ${UserId} ECS instance"
        },
        "VpcId": { "Ref": "SharedVPCId" },
        "SecurityGroupIngress": [
          {
            "IpProtocol": "tcp",
            "FromPort": { "Ref": "ContainerPort" },
            "ToPort": { "Ref": "ContainerPort" },
            "SourceSecurityGroupId": { "Ref": "SharedALBSecurityGroupId" },
            "Description": "Allow traffic from ALB only"
          }
        ],
        "SecurityGroupEgress": [
          {
            "IpProtocol": "tcp",
            "FromPort": 443,
            "ToPort": 443,
            "CidrIp": "0.0.0.0/0",
            "Description": "HTTPS to AWS services and internet"
          },
          {
            "IpProtocol": "tcp",
            "FromPort": 80,
            "ToPort": 80,
            "CidrIp": "0.0.0.0/0",
            "Description": "HTTP for package downloads"
          }
        ],
        "Tags": [
          {
            "Key": "Name",
            "Value": { "Fn::Sub": "elizaos-user-${UserId}-sg" }
          },
          { "Key": "UserId", "Value": { "Ref": "UserId" } },
          { "Key": "UserEmail", "Value": { "Ref": "UserEmail" } },
          { "Key": "Project", "Value": "ElizaOS" },
          { "Key": "Environment", "Value": "production" },
          { "Key": "BillingEntity", "Value": "ElizaOS" },
          { "Key": "CostCenter", "Value": { "Ref": "UserId" } },
          { "Key": "ManagedBy", "Value": "CloudFormation" }
        ]
      }
    },
    "ECSCluster": {
      "Type": "AWS::ECS::Cluster",
      "Properties": {
        "ClusterName": {
          "Fn::Sub": "elizaos-user-${UserId}"
        },
        "ClusterSettings": [
          {
            "Name": "containerInsights",
            "Value": "enabled"
          }
        ],
        "Tags": [
          { "Key": "Name", "Value": { "Fn::Sub": "elizaos-user-${UserId}" } },
          { "Key": "UserId", "Value": { "Ref": "UserId" } },
          { "Key": "UserEmail", "Value": { "Ref": "UserEmail" } },
          { "Key": "Project", "Value": "ElizaOS" },
          { "Key": "Environment", "Value": "production" },
          { "Key": "BillingEntity", "Value": "ElizaOS" },
          { "Key": "CostCenter", "Value": { "Ref": "UserId" } },
          { "Key": "ManagedBy", "Value": "CloudFormation" }
        ]
      }
    },
    "InstanceProfile": {
      "Type": "AWS::IAM::InstanceProfile",
      "Properties": {
        "InstanceProfileName": {
          "Fn::Sub": "elizaos-user-${UserId}-profile"
        },
        "Roles": ["elizaos-ecs-instance-role"]
      }
    },
    "LaunchTemplate": {
      "Type": "AWS::EC2::LaunchTemplate",
      "Properties": {
        "LaunchTemplateName": {
          "Fn::Sub": "elizaos-user-${UserId}-lt"
        },
        "LaunchTemplateData": {
          "ImageId": {
            "Fn::Sub": "{{resolve:ssm:/aws/service/ecs/optimized-ami/amazon-linux-2/recommended/image_id}}"
          },
          "InstanceType": "t3.small",
          "IamInstanceProfile": {
            "Arn": { "Fn::GetAtt": ["InstanceProfile", "Arn"] }
          },
          "KeyName": {
            "Fn::If": [
              "HasKeyPair",
              { "Ref": "KeyName" },
              { "Ref": "AWS::NoValue" }
            ]
          },
          "SecurityGroupIds": [{ "Ref": "UserSecurityGroup" }],
          "UserData": {
            "Fn::Base64": {
              "Fn::Sub": "#!/bin/bash\necho ECS_CLUSTER=${ECSCluster} >> /etc/ecs/ecs.config\necho ECS_ENABLE_CONTAINER_METADATA=true >> /etc/ecs/ecs.config\necho ECS_ENABLE_TASK_IAM_ROLE=true >> /etc/ecs/ecs.config\necho ECS_ENABLE_TASK_CPU_MEM_LIMIT=true >> /etc/ecs/ecs.config\nyum install -y amazon-cloudwatch-agent\n/opt/aws/amazon-cloudwatch-agent/bin/amazon-cloudwatch-agent-ctl \\\n  -a fetch-config \\\n  -m ec2 \\\n  -s -c default\nsystemctl restart docker\n"
            }
          },
          "BlockDeviceMappings": [
            {
              "DeviceName": "/dev/xvda",
              "Ebs": {
                "VolumeSize": 35,
                "VolumeType": "gp3",
                "DeleteOnTermination": true,
                "Encrypted": true,
                "Iops": 3000,
                "Throughput": 125
              }
            }
          ],
          "TagSpecifications": [
            {
              "ResourceType": "instance",
              "Tags": [
                {
                  "Key": "Name",
                  "Value": { "Fn::Sub": "elizaos-user-${UserId}" }
                },
                { "Key": "UserId", "Value": { "Ref": "UserId" } },
                { "Key": "UserEmail", "Value": { "Ref": "UserEmail" } },
                { "Key": "Project", "Value": "ElizaOS" },
                { "Key": "Environment", "Value": "production" },
                { "Key": "BillingEntity", "Value": "ElizaOS" },
                { "Key": "CostCenter", "Value": { "Ref": "UserId" } },
                { "Key": "ManagedBy", "Value": "CloudFormation" }
              ]
            },
            {
              "ResourceType": "volume",
              "Tags": [
                {
                  "Key": "Name",
                  "Value": { "Fn::Sub": "elizaos-user-${UserId}-ebs" }
                },
                { "Key": "UserId", "Value": { "Ref": "UserId" } },
                { "Key": "Project", "Value": "ElizaOS" },
                { "Key": "BillingEntity", "Value": "ElizaOS" },
                { "Key": "CostCenter", "Value": { "Ref": "UserId" } },
                { "Key": "ManagedBy", "Value": "CloudFormation" }
              ]
            }
          ],
          "MetadataOptions": {
            "HttpTokens": "required",
            "HttpPutResponseHopLimit": 2
          }
        }
      }
    },
    "EC2Instance": {
      "Type": "AWS::EC2::Instance",
      "Properties": {
        "LaunchTemplate": {
          "LaunchTemplateId": { "Ref": "LaunchTemplate" },
          "Version": { "Fn::GetAtt": ["LaunchTemplate", "LatestVersionNumber"] }
        },
        "SubnetId": { "Ref": "SharedSubnetId" },
        "Tags": [
          { "Key": "Name", "Value": { "Fn::Sub": "elizaos-user-${UserId}" } },
          { "Key": "UserId", "Value": { "Ref": "UserId" } },
          { "Key": "UserEmail", "Value": { "Ref": "UserEmail" } },
          { "Key": "Project", "Value": "ElizaOS" },
          { "Key": "Environment", "Value": "production" },
          { "Key": "BillingEntity", "Value": "ElizaOS" },
          { "Key": "CostCenter", "Value": { "Ref": "UserId" } },
          { "Key": "ManagedBy", "Value": "CloudFormation" }
        ]
      }
    },
    "EC2RecoveryAlarm": {
      "Type": "AWS::CloudWatch::Alarm",
      "Properties": {
        "AlarmName": { "Fn::Sub": "elizaos-${UserId}-ec2-recovery" },
        "AlarmDescription": "Trigger EC2 recovery if system status check fails",
        "MetricName": "StatusCheckFailed_System",
        "Namespace": "AWS/EC2",
        "Statistic": "Minimum",
        "Period": 60,
        "EvaluationPeriods": 2,
        "Threshold": 1,
        "ComparisonOperator": "GreaterThanOrEqualToThreshold",
        "AlarmActions": [
          { "Fn::Sub": "arn:aws:automate:${AWS::Region}:ec2:recover" }
        ],
        "Dimensions": [
          { "Name": "InstanceId", "Value": { "Ref": "EC2Instance" } }
        ],
        "TreatMissingData": "notBreaching"
      }
    },
    "TargetGroup": {
      "Type": "AWS::ElasticLoadBalancingV2::TargetGroup",
      "Properties": {
        "Name": {
          "Fn::Join": [
            "",
            [
              "eliza-",
              {
                "Fn::Select": [
                  0,
                  { "Fn::Split": ["-", { "Ref": "UserId" }] }
                ]
              },
              "-",
              {
                "Fn::Select": [
                  1,
                  { "Fn::Split": ["-", { "Ref": "UserId" }] }
                ]
              }
            ]
          ]
        },
        "Protocol": "HTTP",
        "Port": { "Ref": "ContainerPort" },
        "VpcId": { "Ref": "SharedVPCId" },
        "TargetType": "instance",
        "HealthCheckEnabled": true,
        "HealthCheckPath": "/health",
        "HealthCheckProtocol": "HTTP",
        "HealthCheckIntervalSeconds": 30,
        "HealthCheckTimeoutSeconds": 5,
        "HealthyThresholdCount": 2,
        "UnhealthyThresholdCount": 3,
        "Matcher": {
          "HttpCode": "200,201"
        },
        "Tags": [
          { "Key": "UserId", "Value": { "Ref": "UserId" } },
          { "Key": "Project", "Value": "ElizaOS" },
          { "Key": "BillingEntity", "Value": "ElizaOS" },
          { "Key": "CostCenter", "Value": { "Ref": "UserId" } },
          { "Key": "ManagedBy", "Value": "CloudFormation" }
        ]
      }
    },
    "UnhealthyTargetAlarm": {
      "Type": "AWS::CloudWatch::Alarm",
      "Condition": "HasSNSTopic",
      "Properties": {
        "AlarmName": { "Fn::Sub": "elizaos-${UserId}-unhealthy-targets" },
        "AlarmDescription": "Alert when targets are unhealthy",
        "MetricName": "UnHealthyHostCount",
        "Namespace": "AWS/ApplicationELB",
        "Statistic": "Average",
        "Period": 60,
        "EvaluationPeriods": 2,
        "Threshold": 1,
        "ComparisonOperator": "GreaterThanOrEqualToThreshold",
        "Dimensions": [
          {
            "Name": "TargetGroup",
            "Value": { "Fn::GetAtt": ["TargetGroup", "TargetGroupFullName"] }
          }
        ],
        "AlarmActions": [{ "Ref": "SNSTopicArn" }],
        "TreatMissingData": "notBreaching"
      }
    },
    "HighCPUAlarm": {
      "Type": "AWS::CloudWatch::Alarm",
      "Condition": "HasSNSTopic",
      "Properties": {
        "AlarmName": { "Fn::Sub": "elizaos-${UserId}-high-cpu" },
        "AlarmDescription": "Alert when CPU utilization is high",
        "MetricName": "CPUUtilization",
        "Namespace": "AWS/ECS",
        "Statistic": "Average",
        "Period": 300,
        "EvaluationPeriods": 2,
        "Threshold": 80,
        "ComparisonOperator": "GreaterThanThreshold",
        "Dimensions": [
          {
            "Name": "ServiceName",
            "Value": { "Fn::GetAtt": ["ECSService", "Name"] }
          },
          {
            "Name": "ClusterName",
            "Value": { "Ref": "ECSCluster" }
          }
        ],
        "AlarmActions": [{ "Ref": "SNSTopicArn" }],
        "TreatMissingData": "notBreaching"
      }
    },
    "HighMemoryAlarm": {
      "Type": "AWS::CloudWatch::Alarm",
      "Condition": "HasSNSTopic",
      "Properties": {
        "AlarmName": { "Fn::Sub": "elizaos-${UserId}-high-memory" },
        "AlarmDescription": "Alert when memory utilization is high",
        "MetricName": "MemoryUtilization",
        "Namespace": "AWS/ECS",
        "Statistic": "Average",
        "Period": 300,
        "EvaluationPeriods": 2,
        "Threshold": 80,
        "ComparisonOperator": "GreaterThanThreshold",
        "Dimensions": [
          {
            "Name": "ServiceName",
            "Value": { "Fn::GetAtt": ["ECSService", "Name"] }
          },
          {
            "Name": "ClusterName",
            "Value": { "Ref": "ECSCluster" }
          }
        ],
        "AlarmActions": [{ "Ref": "SNSTopicArn" }],
        "TreatMissingData": "notBreaching"
      }
    },
    "ListenerRule": {
      "Type": "AWS::ElasticLoadBalancingV2::ListenerRule",
      "Properties": {
        "ListenerArn": { "Ref": "SharedListenerArn" },
        "Priority": { "Ref": "ListenerRulePriority" },
        "Conditions": [
          {
            "Field": "host-header",
            "HostHeaderConfig": {
              "Values": [{ "Fn::Sub": "${UserId}.elizacloud.ai" }]
            }
          }
        ],
        "Actions": [
          {
            "Type": "forward",
            "TargetGroupArn": { "Ref": "TargetGroup" }
          }
        ]
      }
    },
    "LogGroup": {
      "Type": "AWS::Logs::LogGroup",
      "Properties": {
        "LogGroupName": { "Fn::Sub": "/ecs/elizaos-user-${UserId}" },
        "RetentionInDays": 7
      }
    },
    "TaskDefinition": {
      "Type": "AWS::ECS::TaskDefinition",
      "DependsOn": "LogGroup",
      "Properties": {
        "Family": {
          "Fn::Sub": "elizaos-user-${UserId}"
        },
        "NetworkMode": "bridge",
        "RequiresCompatibilities": ["EC2"],
        "Cpu": { "Ref": "ContainerCpu" },
        "Memory": { "Ref": "ContainerMemory" },
        "ExecutionRoleArn": { "Ref": "ECSExecutionRoleArn" },
        "TaskRoleArn": { "Ref": "ECSTaskRoleArn" },
        "ContainerDefinitions": [
          {
            "Name": "agent",
            "Image": { "Ref": "ContainerImage" },
            "Essential": true,
            "PortMappings": [
              {
                "ContainerPort": { "Ref": "ContainerPort" },
                "Protocol": "tcp"
              }
            ],
            "LogConfiguration": {
              "LogDriver": "awslogs",
              "Options": {
                "awslogs-group": { "Fn::Sub": "/ecs/elizaos-user-${UserId}" },
                "awslogs-region": { "Ref": "AWS::Region" },
                "awslogs-stream-prefix": "ecs"
              }
            },
            "HealthCheck": {
              "Command": [
                "CMD-SHELL",
                "curl -f http://localhost:3000/health || exit 1"
              ],
              "Interval": 30,
              "Timeout": 5,
              "Retries": 3,
              "StartPeriod": 60
            }
          }
        ],
        "Tags": [
          { "Key": "UserId", "Value": { "Ref": "UserId" } },
          { "Key": "Project", "Value": "ElizaOS" },
          { "Key": "BillingEntity", "Value": "ElizaOS" },
          { "Key": "CostCenter", "Value": { "Ref": "UserId" } },
          { "Key": "ManagedBy", "Value": "CloudFormation" }
        ]
      }
    },
    "ECSService": {
      "Type": "AWS::ECS::Service",
      "DependsOn": ["EC2Instance", "ListenerRule"],
      "Properties": {
        "ServiceName": {
          "Fn::Sub": "elizaos-user-${UserId}"
        },
        "Cluster": { "Ref": "ECSCluster" },
        "TaskDefinition": { "Ref": "TaskDefinition" },
        "DesiredCount": 1,
        "LaunchType": "EC2",
        "LoadBalancers": [
          {
            "TargetGroupArn": { "Ref": "TargetGroup" },
            "ContainerName": "agent",
            "ContainerPort": { "Ref": "ContainerPort" }
          }
        ],
        "HealthCheckGracePeriodSeconds": 300,
        "DeploymentConfiguration": {
          "MaximumPercent": 100,
          "MinimumHealthyPercent": 0,
          "DeploymentCircuitBreaker": {
            "Enable": true,
            "Rollback": true
          }
        },
        "Tags": [
          { "Key": "UserId", "Value": { "Ref": "UserId" } },
          { "Key": "Project", "Value": "ElizaOS" },
          { "Key": "BillingEntity", "Value": "ElizaOS" },
          { "Key": "CostCenter", "Value": { "Ref": "UserId" } },
          { "Key": "ManagedBy", "Value": "CloudFormation" }
        ]
      }
    }
  },
  "Outputs": {
    "ClusterName": {
      "Description": "ECS Cluster Name",
      "Value": { "Ref": "ECSCluster" }
    },
    "ClusterArn": {
      "Description": "ECS Cluster ARN",
      "Value": { "Fn::GetAtt": ["ECSCluster", "Arn"] }
    },
    "InstanceId": {
      "Description": "EC2 Instance ID",
      "Value": { "Ref": "EC2Instance" }
    },
    "InstancePublicIp": {
      "Description": "EC2 Instance Public IP",
      "Value": { "Fn::GetAtt": ["EC2Instance", "PublicIp"] }
    },
    "ServiceArn": {
      "Description": "ECS Service ARN",
      "Value": { "Ref": "ECSService" }
    },
    "TaskDefinitionArn": {
      "Description": "ECS Task Definition ARN",
      "Value": { "Ref": "TaskDefinition" }
    },
    "TargetGroupArn": {
      "Description": "Target Group ARN",
      "Value": { "Ref": "TargetGroup" }
    },
    "ContainerUrl": {
      "Description": "Container URL",
      "Value": { "Fn::Sub": "https://${UserId}.elizacloud.ai" }
    }
  }
}
