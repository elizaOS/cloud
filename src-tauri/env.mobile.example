# Environment Variables for Mobile Builds
# 
# These are used in CI/CD for building and signing mobile apps.
# Configure as GitHub repository secrets.

# =============================================================================
# iOS BUILD (App Store Connect)
# =============================================================================

# Apple Developer Team ID (found in Xcode > Settings > Accounts)
IOS_DEVELOPMENT_TEAM=YOUR_TEAM_ID

# Code signing identity (e.g., "Apple Distribution: Your Company (TEAMID)")
APPLE_SIGNING_IDENTITY=Apple Distribution: Your Company (TEAMID)

# Base64-encoded .p12 certificate
IOS_CERTIFICATES_P12=<base64-encoded-p12>

# Password for the .p12 certificate
IOS_CERTIFICATES_PASSWORD=your_p12_password

# Base64-encoded provisioning profile (.mobileprovision)
IOS_PROVISIONING_PROFILE=<base64-encoded-mobileprovision>

# App Store Connect API credentials
APP_STORE_CONNECT_API_KEY_ID=your_key_id
APP_STORE_CONNECT_API_ISSUER=your_issuer_id
APP_STORE_CONNECT_API_KEY=<base64-encoded-p8-key>

# =============================================================================
# ANDROID BUILD (Play Store)
# =============================================================================

# Base64-encoded keystore file
ANDROID_KEYSTORE=<base64-encoded-keystore>

# Keystore credentials
ANDROID_STORE_PASSWORD=your_store_password
ANDROID_KEY_ALIAS=your_key_alias
ANDROID_KEY_PASSWORD=your_key_password

# Google Play Service Account JSON (for automated uploads)
PLAY_STORE_SERVICE_ACCOUNT=<service-account-json>

# =============================================================================
# IAP VERIFICATION (Server-side - configure in main app .env)
# =============================================================================

# Apple App Store shared secret (for receipt verification)
# APP_STORE_SHARED_SECRET=your_shared_secret

# Google Play service account (for purchase verification)
# GOOGLE_PLAY_SERVICE_ACCOUNT_KEY=<service-account-json>
