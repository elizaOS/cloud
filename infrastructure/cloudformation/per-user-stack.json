{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Description": "ElizaOS Per-User Container Stack - Production Ready v2 - ECS with Auto Scaling Group, Capacity Provider, and Monitoring",
  "Parameters": {
    "UserId": {
      "Type": "String",
      "Description": "Unique user ID for this deployment"
    },
    "UserEmail": {
      "Type": "String",
      "Description": "User email for tagging",
      "Default": "unknown@example.com"
    },
    "ContainerImage": {
      "Type": "String",
      "Description": "ECR image URI for the container"
    },
    "ContainerPort": {
      "Type": "Number",
      "Default": 3000,
      "Description": "Container port"
    },
    "ContainerCpu": {
      "Type": "Number",
      "Default": 1792,
      "Description": "CPU units (1792 = 1.75 vCPU, 87.5% of t3.small)"
    },
    "ContainerMemory": {
      "Type": "Number",
      "Default": 1792,
      "Description": "Memory in MB (1792 = 1.75 GB, 87.5% of t3.small)"
    },
    "SharedVPCId": {
      "Type": "String",
      "Description": "Shared VPC ID"
    },
    "SharedSubnetId": {
      "Type": "String",
      "Description": "Shared public subnet ID"
    },
    "SharedALBArn": {
      "Type": "String",
      "Description": "Shared ALB ARN"
    },
    "SharedListenerArn": {
      "Type": "String",
      "Description": "Shared ALB HTTPS Listener ARN"
    },
    "SharedALBSecurityGroupId": {
      "Type": "String",
      "Description": "Shared ALB Security Group ID"
    },
    "ECSExecutionRoleArn": {
      "Type": "String",
      "Description": "ECS Task Execution Role ARN"
    },
    "ECSTaskRoleArn": {
      "Type": "String",
      "Description": "ECS Task Role ARN"
    },
    "KeyName": {
      "Type": "String",
      "Description": "EC2 Key Pair for SSH access",
      "Default": ""
    },
    "ListenerRulePriority": {
      "Type": "Number",
      "Description": "ALB Listener Rule Priority (must be unique, 1-50000)",
      "MinValue": 1,
      "MaxValue": 50000
    },
    "SNSTopicArn": {
      "Type": "String",
      "Description": "SNS Topic ARN for alerts (optional)",
      "Default": ""
    }
  },
  "Conditions": {
    "HasKeyPair": {
      "Fn::Not": [{ "Fn::Equals": [{ "Ref": "KeyName" }, ""] }]
    },
    "HasSNSTopic": {
      "Fn::Not": [{ "Fn::Equals": [{ "Ref": "SNSTopicArn" }, ""] }]
    }
  },
  "Resources": {
    "UserSecurityGroup": {
      "Type": "AWS::EC2::SecurityGroup",
      "Properties": {
        "GroupName": {
          "Fn::Sub": "elizaos-user-${UserId}-sg"
        },
        "GroupDescription": {
          "Fn::Sub": "Security group for user ${UserId} ECS instance"
        },
        "VpcId": { "Ref": "SharedVPCId" },
        "SecurityGroupIngress": [
          {
            "IpProtocol": "tcp",
            "FromPort": { "Ref": "ContainerPort" },
            "ToPort": { "Ref": "ContainerPort" },
            "SourceSecurityGroupId": { "Ref": "SharedALBSecurityGroupId" },
            "Description": "Allow traffic from ALB only"
          }
        ],
        "SecurityGroupEgress": [
          {
            "IpProtocol": "tcp",
            "FromPort": 443,
            "ToPort": 443,
            "CidrIp": "0.0.0.0/0",
            "Description": "HTTPS to AWS services and internet"
          },
          {
            "IpProtocol": "tcp",
            "FromPort": 80,
            "ToPort": 80,
            "CidrIp": "0.0.0.0/0",
            "Description": "HTTP for package downloads"
          },
          {
            "IpProtocol": "udp",
            "FromPort": 53,
            "ToPort": 53,
            "CidrIp": "0.0.0.0/0",
            "Description": "DNS (UDP) for name resolution"
          },
          {
            "IpProtocol": "tcp",
            "FromPort": 53,
            "ToPort": 53,
            "CidrIp": "0.0.0.0/0",
            "Description": "DNS (TCP) for large responses/fallback"
          },
          {
            "IpProtocol": "udp",
            "FromPort": 123,
            "ToPort": 123,
            "CidrIp": "0.0.0.0/0",
            "Description": "NTP for time sync"
          }
        ],
        "Tags": [
          {
            "Key": "Name",
            "Value": { "Fn::Sub": "elizaos-user-${UserId}-sg" }
          },
          { "Key": "UserId", "Value": { "Ref": "UserId" } },
          { "Key": "UserEmail", "Value": { "Ref": "UserEmail" } },
          { "Key": "Project", "Value": "ElizaOS" },
          { "Key": "Environment", "Value": "production" },
          { "Key": "BillingEntity", "Value": "ElizaOS" },
          { "Key": "CostCenter", "Value": { "Ref": "UserId" } },
          { "Key": "ManagedBy", "Value": "CloudFormation" }
        ]
      }
    },
    "ECSCluster": {
      "Type": "AWS::ECS::Cluster",
      "Properties": {
        "ClusterName": {
          "Fn::Sub": "elizaos-user-${UserId}"
        },
        "ClusterSettings": [
          {
            "Name": "containerInsights",
            "Value": "enabled"
          }
        ],
        "CapacityProviders": [
          { "Ref": "CapacityProvider" }
        ],
        "DefaultCapacityProviderStrategy": [
          {
            "CapacityProvider": { "Ref": "CapacityProvider" },
            "Weight": 1,
            "Base": 0
          }
        ],
        "Tags": [
          { "Key": "Name", "Value": { "Fn::Sub": "elizaos-user-${UserId}" } },
          { "Key": "UserId", "Value": { "Ref": "UserId" } },
          { "Key": "UserEmail", "Value": { "Ref": "UserEmail" } },
          { "Key": "Project", "Value": "ElizaOS" },
          { "Key": "Environment", "Value": "production" },
          { "Key": "BillingEntity", "Value": "ElizaOS" },
          { "Key": "CostCenter", "Value": { "Ref": "UserId" } },
          { "Key": "ManagedBy", "Value": "CloudFormation" }
        ]
      }
    },
    "InstanceProfile": {
      "Type": "AWS::IAM::InstanceProfile",
      "Properties": {
        "InstanceProfileName": {
          "Fn::Sub": "elizaos-user-${UserId}-profile"
        },
        "Roles": ["elizaos-ecs-instance-role"]
      }
    },
    "LaunchTemplate": {
      "Type": "AWS::EC2::LaunchTemplate",
      "Properties": {
        "LaunchTemplateName": {
          "Fn::Sub": "elizaos-user-${UserId}-lt"
        },
        "LaunchTemplateData": {
          "ImageId": {
            "Fn::Sub": "{{resolve:ssm:/aws/service/ecs/optimized-ami/amazon-linux-2023/recommended/image_id}}"
          },
          "InstanceType": "t3.small",
          "IamInstanceProfile": {
            "Arn": { "Fn::GetAtt": ["InstanceProfile", "Arn"] }
          },
          "KeyName": {
            "Fn::If": [
              "HasKeyPair",
              { "Ref": "KeyName" },
              { "Ref": "AWS::NoValue" }
            ]
          },
          "SecurityGroupIds": [{ "Ref": "UserSecurityGroup" }],
          "UserData": {
            "Fn::Base64": {
              "Fn::Sub": "#!/bin/bash\nset -x\n\n# Log everything to file and console\nexec > >(tee /var/log/user-data.log|logger -t user-data -s 2>/dev/console) 2>&1\n\necho \"========================================\"\necho \"ElizaOS ECS Instance Bootstrap Starting\"\necho \"Cluster: elizaos-user-${UserId}\"\necho \"Time: $(date)\"\necho \"========================================\"\n\nCLUSTER_NAME=\"elizaos-user-${UserId}\"\nREGION=\"${AWS::Region}\"\nSTACK_NAME=\"${AWS::StackName}\"\n\n# Ensure Python and pip (dnf on AL2023)\nif command -v dnf >/dev/null 2>&1; then\n  dnf install -y python3 python3-pip || true\nelse\n  yum install -y python3 || true\nfi\npython3 -m ensurepip --upgrade || true\n\n# Install CloudFormation helper scripts (cfn-signal)\ncurl -fsSL -o /tmp/aws-cfn-bootstrap-py3-latest.tar.gz https://s3.amazonaws.com/cloudformation-examples/aws-cfn-bootstrap-py3-latest.tar.gz\npython3 -m pip install --upgrade /tmp/aws-cfn-bootstrap-py3-latest.tar.gz\n\n# Resolve cfn-signal binary path\nCFN_SIGNAL_BIN=\"$(command -v cfn-signal || echo /opt/aws/bin/cfn-signal)\"\nif [ ! -x \"$CFN_SIGNAL_BIN\" ]; then\n  echo \"ERROR: cfn-signal not found after install\"\n  exit 1\nfi\n\n# Signal function for both success and failure\nsignal_result() {\n  local exit_code=$1\n  local message=$2\n  echo \"$message\"\n  \"$CFN_SIGNAL_BIN\" -e $exit_code --stack \"$STACK_NAME\" --resource AutoScalingGroup --region \"$REGION\"\n  exit $exit_code\n}\n\n# Write ECS configuration BEFORE starting the agent\necho \"Configuring ECS agent for cluster: $CLUSTER_NAME\"\nmkdir -p /etc/ecs\ncat > /etc/ecs/ecs.config << EOF\nECS_CLUSTER=$CLUSTER_NAME\nECS_ENABLE_CONTAINER_METADATA=true\nECS_ENABLE_TASK_IAM_ROLE=true\nECS_ENABLE_TASK_CPU_MEM_LIMIT=true\nECS_CONTAINER_STOP_TIMEOUT=90s\nECS_ENABLE_UNTRACKED_IMAGE_CLEANUP=true\nECS_IMAGE_CLEANUP_INTERVAL=30m\nECS_RESERVED_MEMORY=256\nECS_LOGLEVEL=info\nECS_AVAILABLE_LOGGING_DRIVERS=[\"awslogs\",\"json-file\"]\nECS_ENABLE_SPOT_INSTANCE_DRAINING=false\nEOF\n\n# Stop ECS agent if running and clear any stale state\necho \"Stopping ECS agent and clearing stale state...\"\nsystemctl stop ecs 2>/dev/null || true\nrm -rf /var/lib/ecs/data/agent.db /var/lib/ecs/data/ecs_agent_data.json 2>/dev/null || true\n\n# Wait for Docker/Containerd to be ready\necho \"Waiting for container runtime...\"\nfor i in {1..30}; do\n  if systemctl is-active docker >/dev/null 2>&1 || systemctl is-active containerd >/dev/null 2>&1; then\n    echo \"Container runtime is ready\"\n    break\n  fi\n  if [ $i -eq 30 ]; then\n    signal_result 1 \"ERROR: Container runtime failed to start\"\n  fi\n  sleep 2\ndone\n\n# Start and enable ECS agent\necho \"Starting ECS agent...\"\nsystemctl enable ecs\nsystemctl start ecs\n\n# Wait for ECS agent service to be active\necho \"Waiting for ECS agent service...\"\nfor i in {1..30}; do\n  if systemctl is-active ecs >/dev/null 2>&1; then\n    echo \"ECS agent service is active\"\n    break\n  fi\n  if [ $i -eq 30 ]; then\n    signal_result 1 \"ERROR: ECS agent service failed to start\"\n  fi\n  sleep 2\ndone\n\n# Wait for ECS agent introspection endpoint\necho \"Waiting for ECS agent introspection endpoint...\"\nfor i in {1..30}; do\n  if curl -s http://localhost:51678/v1/metadata >/dev/null 2>&1; then\n    echo \"ECS agent introspection endpoint is responding\"\n    break\n  fi\n  if [ $i -eq 30 ]; then\n    signal_result 1 \"ERROR: ECS agent introspection endpoint not responding\"\n  fi\n  sleep 2\ndone\n\n# Verify registration with ECS cluster\necho \"Verifying ECS cluster registration...\"\nfor i in {1..60}; do\n  METADATA=$(curl -s http://localhost:51678/v1/metadata)\n  if echo \"$METADATA\" | grep -q \"$CLUSTER_NAME\"; then\n    echo \"✅ Successfully registered with cluster: $CLUSTER_NAME\"\n    echo \"$METADATA\" | tee /var/log/ecs-introspection.json\n    \n    # Additional verification: Check if instance appears in cluster\n    sleep 5\n    INSTANCE_ARN=$(echo \"$METADATA\" | grep -o '\"ContainerInstanceArn\":\"[^\"]*\"' | cut -d'\"' -f4)\n    echo \"Container Instance ARN: $INSTANCE_ARN\"\n    \n    signal_result 0 \"✅ ECS instance successfully bootstrapped\"\n  fi\n  if [ $i -eq 60 ]; then\n    echo \"ERROR: Failed to register with cluster after 2 minutes\"\n    echo \"Last metadata response: $METADATA\"\n    signal_result 1 \"ERROR: ECS cluster registration timeout\"\n  fi\n  echo \"Waiting for cluster registration (attempt $i/60)...\"\n  sleep 2\ndone\n"
            }
          },
          "BlockDeviceMappings": [
            {
              "DeviceName": "/dev/xvda",
              "Ebs": {
                "VolumeSize": 35,
                "VolumeType": "gp3",
                "DeleteOnTermination": true,
                "Encrypted": true,
                "Iops": 3000,
                "Throughput": 125
              }
            }
          ],
          "TagSpecifications": [
            {
              "ResourceType": "instance",
              "Tags": [
                {
                  "Key": "Name",
                  "Value": { "Fn::Sub": "elizaos-user-${UserId}" }
                },
                { "Key": "UserId", "Value": { "Ref": "UserId" } },
                { "Key": "UserEmail", "Value": { "Ref": "UserEmail" } },
                { "Key": "Project", "Value": "ElizaOS" },
                { "Key": "Environment", "Value": "production" },
                { "Key": "BillingEntity", "Value": "ElizaOS" },
                { "Key": "CostCenter", "Value": { "Ref": "UserId" } },
                { "Key": "ManagedBy", "Value": "CloudFormation" }
              ]
            },
            {
              "ResourceType": "volume",
              "Tags": [
                {
                  "Key": "Name",
                  "Value": { "Fn::Sub": "elizaos-user-${UserId}-ebs" }
                },
                { "Key": "UserId", "Value": { "Ref": "UserId" } },
                { "Key": "Project", "Value": "ElizaOS" },
                { "Key": "BillingEntity", "Value": "ElizaOS" },
                { "Key": "CostCenter", "Value": { "Ref": "UserId" } },
                { "Key": "ManagedBy", "Value": "CloudFormation" }
              ]
            }
          ],
          "MetadataOptions": {
            "HttpTokens": "required",
            "HttpPutResponseHopLimit": 2
          }
        }
      }
    },
    "AutoScalingGroup": {
      "Type": "AWS::AutoScaling::AutoScalingGroup",
      "CreationPolicy": {
        "ResourceSignal": {
          "Timeout": "PT15M",
          "Count": 1
        }
      },
      "UpdatePolicy": {
        "AutoScalingReplacingUpdate": {
          "WillReplace": true
        }
      },
      "Properties": {
        "AutoScalingGroupName": {
          "Fn::Sub": "elizaos-user-${UserId}-asg"
        },
        "VPCZoneIdentifier": [{ "Ref": "SharedSubnetId" }],
        "LaunchTemplate": {
          "LaunchTemplateId": { "Ref": "LaunchTemplate" },
          "Version": { "Fn::GetAtt": ["LaunchTemplate", "LatestVersionNumber"] }
        },
        "MinSize": "1",
        "MaxSize": "1",
        "DesiredCapacity": "1",
        "HealthCheckType": "EC2",
        "HealthCheckGracePeriod": 300,
        "NewInstancesProtectedFromScaleIn": false,
        "Tags": [
          {
            "Key": "Name",
            "Value": { "Fn::Sub": "elizaos-user-${UserId}" },
            "PropagateAtLaunch": true
          },
          {
            "Key": "UserId",
            "Value": { "Ref": "UserId" },
            "PropagateAtLaunch": true
          },
          {
            "Key": "UserEmail",
            "Value": { "Ref": "UserEmail" },
            "PropagateAtLaunch": true
          },
          {
            "Key": "Project",
            "Value": "ElizaOS",
            "PropagateAtLaunch": true
          },
          {
            "Key": "Environment",
            "Value": "production",
            "PropagateAtLaunch": true
          },
          {
            "Key": "BillingEntity",
            "Value": "ElizaOS",
            "PropagateAtLaunch": true
          },
          {
            "Key": "CostCenter",
            "Value": { "Ref": "UserId" },
            "PropagateAtLaunch": true
          },
          {
            "Key": "ManagedBy",
            "Value": "CloudFormation",
            "PropagateAtLaunch": true
          }
        ]
      }
    },
    "CapacityProvider": {
      "Type": "AWS::ECS::CapacityProvider",
      "Properties": {
        "Name": {
          "Fn::Sub": "elizaos-user-${UserId}-cp"
        },
        "AutoScalingGroupProvider": {
          "AutoScalingGroupArn": { "Ref": "AutoScalingGroup" },
          "ManagedScaling": {
            "Status": "DISABLED",
            "TargetCapacity": 100
          },
          "ManagedTerminationProtection": "DISABLED"
        },
        "Tags": [
          { "Key": "UserId", "Value": { "Ref": "UserId" } },
          { "Key": "Project", "Value": "ElizaOS" },
          { "Key": "BillingEntity", "Value": "ElizaOS" },
          { "Key": "CostCenter", "Value": { "Ref": "UserId" } },
          { "Key": "ManagedBy", "Value": "CloudFormation" }
        ]
      }
    },
    "TargetGroup": {
      "Type": "AWS::ElasticLoadBalancingV2::TargetGroup",
      "Properties": {
        "Name": {
          "Fn::Join": [
            "",
            [
              "eliza-",
              {
                "Fn::Select": [
                  0,
                  { "Fn::Split": ["-", { "Ref": "UserId" }] }
                ]
              },
              "-",
              {
                "Fn::Select": [
                  1,
                  { "Fn::Split": ["-", { "Ref": "UserId" }] }
                ]
              }
            ]
          ]
        },
        "Protocol": "HTTP",
        "Port": { "Ref": "ContainerPort" },
        "VpcId": { "Ref": "SharedVPCId" },
        "TargetType": "instance",
        "HealthCheckEnabled": true,
        "HealthCheckPath": "/health",
        "HealthCheckProtocol": "HTTP",
        "HealthCheckIntervalSeconds": 30,
        "HealthCheckTimeoutSeconds": 5,
        "HealthyThresholdCount": 2,
        "UnhealthyThresholdCount": 3,
        "Matcher": {
          "HttpCode": "200,201"
        },
        "Tags": [
          { "Key": "UserId", "Value": { "Ref": "UserId" } },
          { "Key": "Project", "Value": "ElizaOS" },
          { "Key": "BillingEntity", "Value": "ElizaOS" },
          { "Key": "CostCenter", "Value": { "Ref": "UserId" } },
          { "Key": "ManagedBy", "Value": "CloudFormation" }
        ]
      }
    },
    "UnhealthyTargetAlarm": {
      "Type": "AWS::CloudWatch::Alarm",
      "Condition": "HasSNSTopic",
      "Properties": {
        "AlarmName": { "Fn::Sub": "elizaos-${UserId}-unhealthy-targets" },
        "AlarmDescription": "Alert when targets are unhealthy",
        "MetricName": "UnHealthyHostCount",
        "Namespace": "AWS/ApplicationELB",
        "Statistic": "Average",
        "Period": 60,
        "EvaluationPeriods": 2,
        "Threshold": 1,
        "ComparisonOperator": "GreaterThanOrEqualToThreshold",
        "Dimensions": [
          {
            "Name": "TargetGroup",
            "Value": { "Fn::GetAtt": ["TargetGroup", "TargetGroupFullName"] }
          }
        ],
        "AlarmActions": [{ "Ref": "SNSTopicArn" }],
        "TreatMissingData": "notBreaching"
      }
    },
    "HighCPUAlarm": {
      "Type": "AWS::CloudWatch::Alarm",
      "Condition": "HasSNSTopic",
      "Properties": {
        "AlarmName": { "Fn::Sub": "elizaos-${UserId}-high-cpu" },
        "AlarmDescription": "Alert when CPU utilization is high",
        "MetricName": "CPUUtilization",
        "Namespace": "AWS/ECS",
        "Statistic": "Average",
        "Period": 300,
        "EvaluationPeriods": 2,
        "Threshold": 80,
        "ComparisonOperator": "GreaterThanThreshold",
        "Dimensions": [
          {
            "Name": "ServiceName",
            "Value": { "Fn::GetAtt": ["ECSService", "Name"] }
          },
          {
            "Name": "ClusterName",
            "Value": { "Ref": "ECSCluster" }
          }
        ],
        "AlarmActions": [{ "Ref": "SNSTopicArn" }],
        "TreatMissingData": "notBreaching"
      }
    },
    "HighMemoryAlarm": {
      "Type": "AWS::CloudWatch::Alarm",
      "Condition": "HasSNSTopic",
      "Properties": {
        "AlarmName": { "Fn::Sub": "elizaos-${UserId}-high-memory" },
        "AlarmDescription": "Alert when memory utilization is high",
        "MetricName": "MemoryUtilization",
        "Namespace": "AWS/ECS",
        "Statistic": "Average",
        "Period": 300,
        "EvaluationPeriods": 2,
        "Threshold": 80,
        "ComparisonOperator": "GreaterThanThreshold",
        "Dimensions": [
          {
            "Name": "ServiceName",
            "Value": { "Fn::GetAtt": ["ECSService", "Name"] }
          },
          {
            "Name": "ClusterName",
            "Value": { "Ref": "ECSCluster" }
          }
        ],
        "AlarmActions": [{ "Ref": "SNSTopicArn" }],
        "TreatMissingData": "notBreaching"
      }
    },
    "ListenerRule": {
      "Type": "AWS::ElasticLoadBalancingV2::ListenerRule",
      "Properties": {
        "ListenerArn": { "Ref": "SharedListenerArn" },
        "Priority": { "Ref": "ListenerRulePriority" },
        "Conditions": [
          {
            "Field": "host-header",
            "HostHeaderConfig": {
              "Values": [{ "Fn::Sub": "${UserId}.elizacloud.ai" }]
            }
          }
        ],
        "Actions": [
          {
            "Type": "forward",
            "TargetGroupArn": { "Ref": "TargetGroup" }
          }
        ]
      }
    },
    "LogGroup": {
      "Type": "AWS::Logs::LogGroup",
      "Properties": {
        "LogGroupName": { "Fn::Sub": "/ecs/elizaos-user-${UserId}" },
        "RetentionInDays": 7
      }
    },
    "TaskDefinition": {
      "Type": "AWS::ECS::TaskDefinition",
      "DependsOn": "LogGroup",
      "Properties": {
        "Family": {
          "Fn::Sub": "elizaos-user-${UserId}"
        },
        "NetworkMode": "bridge",
        "RequiresCompatibilities": ["EC2"],
        "Cpu": { "Ref": "ContainerCpu" },
        "Memory": { "Ref": "ContainerMemory" },
        "ExecutionRoleArn": { "Ref": "ECSExecutionRoleArn" },
        "TaskRoleArn": { "Ref": "ECSTaskRoleArn" },
        "ContainerDefinitions": [
          {
            "Name": "agent",
            "Image": { "Ref": "ContainerImage" },
            "Essential": true,
            "PortMappings": [
              {
                "ContainerPort": { "Ref": "ContainerPort" },
                "HostPort": { "Ref": "ContainerPort" },
                "Protocol": "tcp"
              }
            ],
            "LogConfiguration": {
              "LogDriver": "awslogs",
              "Options": {
                "awslogs-group": { "Fn::Sub": "/ecs/elizaos-user-${UserId}" },
                "awslogs-region": { "Ref": "AWS::Region" },
                "awslogs-stream-prefix": "ecs"
              }
            },
            "HealthCheck": {
              "Command": [
                "CMD-SHELL",
                "curl -f http://localhost:3000/health || exit 1"
              ],
              "Interval": 30,
              "Timeout": 5,
              "Retries": 3,
              "StartPeriod": 60
            }
          }
        ],
        "Tags": [
          { "Key": "UserId", "Value": { "Ref": "UserId" } },
          { "Key": "Project", "Value": "ElizaOS" },
          { "Key": "BillingEntity", "Value": "ElizaOS" },
          { "Key": "CostCenter", "Value": { "Ref": "UserId" } },
          { "Key": "ManagedBy", "Value": "CloudFormation" }
        ]
      }
    },
    "ECSService": {
      "Type": "AWS::ECS::Service",
      "DependsOn": ["AutoScalingGroup", "ListenerRule", "TargetGroup"],
      "Properties": {
        "ServiceName": {
          "Fn::Sub": "elizaos-user-${UserId}"
        },
        "Cluster": { "Ref": "ECSCluster" },
        "TaskDefinition": { "Ref": "TaskDefinition" },
        "DesiredCount": 1,
        "CapacityProviderStrategy": [
          {
            "CapacityProvider": { "Ref": "CapacityProvider" },
            "Weight": 1,
            "Base": 0
          }
        ],
        "LoadBalancers": [
          {
            "TargetGroupArn": { "Ref": "TargetGroup" },
            "ContainerName": "agent",
            "ContainerPort": { "Ref": "ContainerPort" }
          }
        ],
        "HealthCheckGracePeriodSeconds": 900,
        "DeploymentConfiguration": {
          "MaximumPercent": 100,
          "MinimumHealthyPercent": 0,
          "DeploymentCircuitBreaker": {
            "Enable": false,
            "Rollback": false
          }
        },
        "PlacementStrategies": [
          {
            "Type": "spread",
            "Field": "instanceId"
          }
        ],
        "Tags": [
          { "Key": "UserId", "Value": { "Ref": "UserId" } },
          { "Key": "Project", "Value": "ElizaOS" },
          { "Key": "BillingEntity", "Value": "ElizaOS" },
          { "Key": "CostCenter", "Value": { "Ref": "UserId" } },
          { "Key": "ManagedBy", "Value": "CloudFormation" }
        ]
      }
    }
  },
  "Outputs": {
