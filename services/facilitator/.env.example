# =============================================================================
# x402 Facilitator Configuration
# =============================================================================
# Copy this file to .env and fill in the required values.
#
#   cp .env.example .env
#
# The facilitator is a settlement service that verifies ERC-2612 permits
# and settles USDC payments on supported EVM networks.
# =============================================================================

# ---------------------------------------------------------------------------
# REQUIRED — Facilitator signer private key
# ---------------------------------------------------------------------------
# The facilitator uses this key to co-sign and settle payments on-chain.
# Must be a hex-encoded 32-byte private key prefixed with 0x.
# Fund this address with a small amount of ETH for gas on each target network.
FACILITATOR_PRIVATE_KEY=0x...

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
PORT=8090

# ---------------------------------------------------------------------------
# Networks (comma-separated)
# ---------------------------------------------------------------------------
# Supported values: base-sepolia, base, ethereum, ethereum-sepolia
# The facilitator will only accept payments on these networks.
EVM_NETWORKS=base-sepolia,base

# ---------------------------------------------------------------------------
# Optional: Coinbase Developer Platform (CDP) credentials
# ---------------------------------------------------------------------------
# Used for advanced on-chain settlement and wallet management.
# Get from: https://portal.cdp.coinbase.com
# CDP_API_KEY=
# CDP_API_SECRET=

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
# Levels: trace, debug, info, warn, error, fatal
LOG_LEVEL=info
