  "facilitators": {
    "_comment": "x402 facilitators for payment verification and settlement",
    "coinbase": {
      "name": "Coinbase CDP",
      "type": "cdp",
      "networks": ["base", "base-sepolia"],
      "requiresCredentials": true,
      "envKeys": ["CDP_API_KEY_ID", "CDP_API_KEY_SECRET"]
    },
    "jeju": {
      "name": "Jeju Decentralized Facilitator",
      "type": "decentralized",
      "networks": ["jeju", "jeju-testnet", "jeju-localnet"],
      "contractAddress": "0x0000000000000000000000000000000000000000",
      "requiresCredentials": false
    },
    "public": {
      "name": "Public Facilitator (Rate Limited)",
      "type": "public",
      "networks": ["base", "base-sepolia"],
      "requiresCredentials": false,
      "rateLimited": true
    }
  },

  "elizaToken": {
    "_comment": "ElizaOS Token addresses - payout destinations",
    "evm": {
      "ethereum": "0xea17df5cf6d172224892b5477a16acb111182478",
      "base": "0xea17df5cf6d172224892b5477a16acb111182478",
      "base-sepolia": "0x7af64e6aE21076DE21EFe71F243A75664a17C34b",
      "bnb": "0xea17df5cf6d172224892b5477a16acb111182478",
      "jeju": "0x0000000000000000000000000000000000000000",
      "jeju-testnet": "0x0000000000000000000000000000000000000000"
    },
    "solana": "DuMbhu7mvQvqQHGcnikDgb4XegXJRyhUBfdU22uELiZA"
  },

  "oifContracts": {
    "_comment": "Open Intents Framework contracts - deployed 2025-12-09",
    "base-sepolia": {
      "SolverRegistry": "0xecfE47302D941c8ce5B0009C0ac2E6D6ee2A42de",
      "SimpleOracle": "0xE30218678a940d1553b285B0eB5C5364BBF70ed9",
      "InputSettler": "0x9bb59d0329FcCEdD99f1753D20AF50347Ad2eB75",
      "OutputSettler": "0xf7ef3C6a54dA3E03A96D23864e5865E7e3EBEcF5",
      "_deployed": "2025-12-09",
      "_deployer": "0x5dB1268e424da5C26451e4a8B9C221e6DE3C3064"
    },
    "jeju-testnet": {
      "SolverRegistry": "0x0000000000000000000000000000000000000000",
      "SimpleOracle": "0x0000000000000000000000000000000000000000",
      "InputSettler": "0x0000000000000000000000000000000000000000",
      "OutputSettler": "0x0000000000000000000000000000000000000000",
      "_note": "Deploy when Jeju testnet RPC is live"
    },
    "jeju": {
      "SolverRegistry": "0x0000000000000000000000000000000000000000",
      "SuperchainOracle": "0x0000000000000000000000000000000000000000",
      "InputSettler": "0x0000000000000000000000000000000000000000",
      "OutputSettler": "0x0000000000000000000000000000000000000000",
      "_note": "Deploy when Jeju mainnet is live"
    }
  },

  "crossChainPayments": {
    "_comment": "OIF/EIL-based cross-chain payment routing - requires JEJU_DEPLOYED=true and OIF contracts",
    "enabled": false,
    "supportedSourceChains": {
      "mainnet": [1, 42161, 10, 8453, 420691],
      "testnet": [11155111, 84532, 420690]
    },
    "oifIntegration": {
      "enabled": true,
      "aggregatorUrl": "http://localhost:4010",
      "aggregatorUrlProduction": "https://intents.jeju.network"
    },
    "eilIntegration": {
      "enabled": true,
      "crossChainPaymaster": true,
      "supportedPaymentTokens": ["USDC", "ETH", "WETH"]
    },
    "settlementChains": {
      "primary": "jeju",
      "fallback": "base",
      "testnetPrimary": "jeju-testnet",
      "testnetFallback": "base-sepolia"
    }
  },

  "accountAbstraction": {
    "_comment": "ERC-4337 and ERC-7702. Enable paymasterEnabled when paymaster deployed.",
    "erc4337": {
      "enabled": true,
      "entryPoint": "0x0000000071727De22E5E9d8BAf0edAc6f37da032",
      "paymasterEnabled": false
    },
    "erc7702": {
      "enabled": false,
      "_comment": "Enable when EIP-7702 is available on Jeju"
    },
    "batchTransactions": {
      "enabled": true,
      "maxBatchSize": 10
    }
  },

  "defaults": {
    "_comment": "Defaults to Base until Jeju contracts are deployed. Set JEJU_DEPLOYED=true when ready.",
    "network": "base-sepolia",
    "productionNetwork": "base",
    "localnetNetwork": "jeju-localnet",
    "jejuNetwork": "jeju-testnet",
    "jejuProductionNetwork": "jeju",
    "fallbackNetwork": "base-sepolia",
    "fallbackProductionNetwork": "base"
  }
}

