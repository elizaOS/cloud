# E2E Test Environment Variables
# Copy this file to .env and fill in the values

# Test wallet configuration
# IMPORTANT: Use a dedicated test wallet. NEVER use a wallet with real funds!
# Generate a new seed phrase for testing: https://iancoleman.io/bip39/
TEST_WALLET_SEED_PHRASE="test test test test test test test test test test test junk"
TEST_WALLET_PASSWORD="TestPassword123!"

# Base URL for tests (defaults to http://localhost:3000)
PLAYWRIGHT_BASE_URL="http://localhost:3000"

# Optional: Pre-authenticated token for testing authenticated states
# Get this from browser dev tools after logging in
# TEST_AUTH_TOKEN=""

# Optional: Test user credentials for email login tests
# TEST_USER_EMAIL="test@example.com"
# TEST_USER_CODE="" # OTP code if known




