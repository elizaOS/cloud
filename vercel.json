{
  "crons": [
    {
      "path": "/api/cron/cleanup-priorities",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/cleanup-cli-sessions",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/v1/cron/health-check",
      "schedule": "*/5 * * * *"
    }
  ],
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "nextjs"
}
