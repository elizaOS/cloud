{
  "name": "@elizaos/cloud",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "packages/services/*",
    "services/agent-server"
  ],
  "scripts": {
    "postinstall": "find node_modules -path '*/thread-stream/test' -type d -exec rm -rf {} + 2>/dev/null || true; find node_modules -path '*/thread-stream/bench.js' -delete 2>/dev/null || true; find node_modules -path '*/thread-stream/LICENSE' -delete 2>/dev/null || true; find node_modules -path '*/thread-stream/README.md' -delete 2>/dev/null || true; node packages/scripts/postinstall.mjs",
    "setup": "bun run packages/scripts/setup.ts",
    "setup:check": "bun run packages/scripts/setup.ts --check",
    "dev": "next dev --turbopack",
    "dev:local": "DEV_LINKED=1 next dev --webpack",
    "dev:quick": "next dev --turbopack",
    "dev:x402": "bun run packages/scripts/dev-x402.ts",
    "dev:full": "bun run setup:check && bun run dev:quick",
    "generate:llms": "tsx packages/scripts/generate-llms-txt.ts",
    "generate:jwt-keys": "bun run packages/scripts/generate-jwt-keys.ts",
    "clean:test-next-dirs": "node -e \"const fs=require('node:fs'); const path=require('node:path'); for (const name of fs.readdirSync('.')) { if (/^\\\\.next-test-/.test(name)) { fs.rmSync(path.join('.', name), { recursive: true, force: true }); } }\"",
    "build": "bun run clean:test-next-dirs && bun run generate:llms && NEXT_DIST_DIR=.next-build LOG_LEVEL=error NODE_NO_WARNINGS=1 next build",
    "build:deploy": "bun run clean:test-next-dirs && bun run generate:llms && NODE_OPTIONS=\"${NODE_OPTIONS:---max-old-space-size=6144}\" NEXT_DIST_DIR=.next-build LOG_LEVEL=error NODE_NO_WARNINGS=1 next build --webpack",
    "build:analyze": "NEXT_DIST_DIR=.next-analyze ANALYZE=true next build",
    "start": "next start",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "verify": "bun run lint && bun run check-types && bun run check-types:tests && bun run check-types:ui && bun run check-types:agent-server && bun run check-types:gateway-discord && bun run check-types:gateway-webhook",
    "check-types": "bun run packages/scripts/check-types-split.ts",
    "check-types:full": "bun ./node_modules/typescript/lib/tsc.js --noEmit",
    "check-types:tests": "bun ./node_modules/typescript/lib/tsc.js --noEmit --project tsconfig.test.json",
    "check-types:ui": "bun run --cwd packages/ui typecheck",
    "check-types:agent-server": "bun run --cwd services/agent-server typecheck",
    "check-types:gateway-discord": "bun run --cwd packages/services/gateway-discord typecheck",
    "check-types:gateway-webhook": "bun run --cwd packages/services/gateway-webhook typecheck",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:local:setup": "tsx packages/scripts/setup-local-db-comprehensive.ts",
    "db:local:start": "docker-compose up -d",
    "db:local:stop": "docker-compose down",
    "db:local:clean": "docker-compose down -v && docker network prune -f",
    "db:local:logs": "docker-compose logs -f postgres",
    "db:local:seed": "tsx packages/scripts/seed-local-dev.ts",
    "db:audit": "bun run packages/scripts/audit-migrations.ts",
    "db:check-migrations": "bun run packages/scripts/check-migration-journal.ts",
    "db:repair-journal": "bun run packages/scripts/repair-drizzle-journal.ts",
    "seed:credit-packs": "tsx packages/scripts/seed-credit-packs.ts",
    "stripe:webhook": "stripe listen --forward-to localhost:3000/api/stripe/webhook",
    "cron:auto-top-up": "tsx packages/scripts/trigger-auto-top-up.ts",
    "billing:set-email": "tsx packages/scripts/set-billing-email.ts",
    "bootstrapper:build": "cd bootstrapper && ./build.sh",
    "cache:clear": "tsx packages/scripts/clear-cache.ts",
    "cache:health": "tsx packages/scripts/cache-health-check.ts",
    "eliza-app:cleanup": "bun run packages/scripts/cleanup-eliza-app-user.ts",
    "steward:backfill-users": "bun run packages/scripts/backfill-steward-users.ts",
    "mcp:inspector": "bunx @modelcontextprotocol/inspector@latest",
    "admin:promote": "bun run packages/scripts/promote-admin.ts",
    "admin:list": "bun run packages/scripts/promote-admin.ts --list",
    "admin:revoke": "bun run packages/scripts/promote-admin.ts --revoke",
    "test:unit": "SKIP_DB_DEPENDENT=1 SKIP_SERVER_CHECK=true bun test --preload ./packages/tests/load-env.ts packages/tests/unit",
    "test:repo-unit:bulk": "SKIP_DB_DEPENDENT=1 SKIP_SERVER_CHECK=true bun test --max-concurrency=1 --preload ./packages/tests/load-env.ts $(find packages/tests/unit -name '*.test.ts' ! -path 'packages/tests/unit/credits.test.ts' ! -path 'packages/tests/unit/docker-infrastructure.test.ts' ! -path 'packages/tests/unit/eliza-app/discord-auth.test.ts' ! -path 'packages/tests/unit/eliza-agent-web-ui.test.ts' ! -path 'packages/tests/unit/oauth/secrets-adapter-utils.test.ts' | sort) packages/lib/services/gateway-discord/__tests__ packages/services/gateway-discord/tests/gateway-manager.test.ts packages/services/gateway-discord/tests/leader-election.test.ts packages/services/gateway-discord/tests/logger.test.ts packages/services/gateway-discord/tests/voice-message-handler.test.ts",
    "test:repo-unit:special": "SKIP_DB_DEPENDENT=1 SKIP_SERVER_CHECK=true bun test --preload ./packages/tests/load-env.ts packages/tests/unit/credits.test.ts packages/tests/unit/eliza-app/discord-auth.test.ts packages/tests/unit/eliza-agent-web-ui.test.ts",
    "test:repo-unit:isolated": "SKIP_DB_DEPENDENT=1 SKIP_SERVER_CHECK=true bun test --preload ./packages/tests/load-env.ts packages/tests/unit/docker-infrastructure.test.ts && SKIP_DB_DEPENDENT=1 SKIP_SERVER_CHECK=true bun test --preload ./packages/tests/load-env.ts packages/tests/unit/oauth/secrets-adapter-utils.test.ts",
    "test:integration": "bun test --max-concurrency=1 --preload ./packages/tests/e2e/preload.ts packages/tests/integration --timeout 120000",
    "test:services": "bun test --max-concurrency=1 --preload ./packages/tests/load-env.ts packages/tests/integration/services --timeout 120000",
    "test:properties": "bun test --max-concurrency=1 --preload ./packages/tests/load-env.ts packages/tests/properties --timeout 300000",
    "test:runtime": "bun test --max-concurrency=1 --preload ./packages/tests/load-env.ts packages/tests/runtime --timeout 120000",
    "test:mcp": "bun test --preload ./packages/tests/load-env.ts packages/tests/runtime/mcp-loading.test.ts --timeout 120000",
    "test:oauth": "bun test --preload ./packages/tests/e2e/preload.ts packages/tests/integration/unified-oauth-api.test.ts --timeout 120000",
    "test:oauth:manual": "./packages/tests/manual/oauth-manual-test.sh",
    "test:e2e:api": "bun test --max-concurrency=1 --preload ./packages/tests/e2e/preload.ts packages/tests/e2e/api --timeout 120000",
    "test:e2e:v1": "bun test --max-concurrency=1 --preload ./packages/tests/e2e/preload.ts packages/tests/e2e/v1 --timeout 120000",
    "test:e2e:smoke": "node scripts/run-e2e-smoke.mjs",
    "test:e2e:miniapp": "bun test --max-concurrency=1 --preload ./packages/tests/e2e/preload.ts packages/tests/e2e/v1/miniapp-lifecycle.test.ts packages/tests/e2e/v1/app-monetization.test.ts packages/tests/e2e/v1/agent-publishing.test.ts packages/tests/e2e/v1/credits-billing.test.ts packages/tests/e2e/v1/affiliate-miniapp.test.ts --timeout 120000",
    "test:e2e:all": "bun run test:e2e:api && bun run test:e2e:v1 && bun run test:e2e:miniapp",
    "test:secrets": "node ../../scripts/check-secret-hygiene.mjs",
    "test": "bun run test:secrets && bun run test:repo-unit:bulk && bun run test:repo-unit:special && bun run test:repo-unit:isolated",
    "test:playwright": "playwright test",
    "test:playwright:auth": "PLAYWRIGHT_REAL_AUTH=true playwright test packages/tests/playwright/auth-real.spec.ts --grep @auth-real --headed"
  },
