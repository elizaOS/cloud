{
  "extends": "../../../tsconfig.json",
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["dom", "dom.iterable", "esnext"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "allowImportingTsExtensions": false,
    "types": ["vite/client", "node"],
    "baseUrl": ".",
    "paths": {
      "@/lib/*": ["../../lib/*"],
      "@/db/*": ["../../db/*"],
      "@/types/*": ["../../types/*"],
      "@/components/*": ["../../ui/src/components/*"],
      "@/packages/*": ["../../*"],
      "@elizaos/cloud-ui": ["../../ui/src/index.ts"],
      "@elizaos/cloud-ui/*": ["../../ui/src/*"],
      "@/*": ["./src/*"]
    }
  },
  "include": ["src", "vite.config.ts", "../../ui/src", "../../lib"],
  "exclude": [
    "node_modules",
    "dist",
    "src/legacy",
    "../../ui/src/**/*.stories.ts",
    "../../ui/src/**/*.stories.tsx",
    "../../ui/src/**/*.test.ts",
    "../../ui/src/**/*.test.tsx",
    "../../ui/storybook-static",
    "../../lib/**/__tests__",
    "../../lib/**/*.test.ts",
    "../../lib/**/*.test.tsx",
    "../../ui/src/components/billing/billing-page-client.tsx",
    "../../ui/src/components/settings/tabs/billing-tab.tsx",
    "../../ui/src/components/settings/crypto-payment-modal.tsx"
  ]
}
