# Database - Local Development
DATABASE_URL="postgresql://eliza_dev:local_dev_password@localhost:5432/eliza_dev"

# Privy Authentication
NEXT_PUBLIC_PRIVY_APP_ID=
NEXT_PUBLIC_PRIVY_CLIENT_ID=
PRIVY_APP_SECRET=

# STRIPE
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SMALL_PACK_PRICE_ID=
STRIPE_SMALL_PACK_PRODUCT_ID=
STRIPE_MEDIUM_PACK_PRICE_ID=
STRIPE_MEDIUM_PACK_PRODUCT_ID=
STRIPE_LARGE_PACK_PRICE_ID=
STRIPE_LARGE_PACK_PRODUCT_ID=

# FAL AI (for image/video generation)
FAL_KEY="your_fal_key_here"

# App Configuration
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# Credits SSE Feature Flag (set to "false" to disable real-time credit updates)
NEXT_PUBLIC_CREDITS_SSE_ENABLED="true"

# SSE Connection Timeout (milliseconds)
# Default: 30 minutes (1800000ms)
# Recommended: 30-60 minutes for production
# See ANALYTICS_PR_REVIEW_ANALYSIS.md - Issue #4
SSE_CONNECTION_TIMEOUT="1800000"

# Redis/Upstash Configuration (for caching and rate limiting)
KV_REST_API_URL="https://your-endpoint.upstash.io"
KV_REST_API_TOKEN="your_token_here"
KV_URL="redis_url_here"
KV_REST_API_READ_ONLY_TOKEN="your_read_only_token_here"
REDIS_URL="redis_url_here"

# Cache Feature Flag (set to "false" to disable caching)
CACHE_ENABLED="true"

# Redis-Backed Rate Limiting (REQUIRED for production)
# Set to "true" for distributed rate limiting across serverless instances
# Set to "false" for in-memory rate limiting (development only)
REDIS_RATE_LIMITING="true"
# VERCEL
AI_GATEWAY_API_KEY=
OPENAI_API_KEY=
BLOB_READ_WRITE_TOKEN=
