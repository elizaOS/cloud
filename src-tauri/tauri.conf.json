{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Eliza Cloud",
  "version": "0.1.0",
  "identifier": "ai.elizacloud.mobile",
  "build": {
    "beforeDevCommand": "bun run dev:quick",
    "devUrl": "http://localhost:3000",
    "frontendDist": "./dist"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "iOS": {
      "developmentTeam": "${IOS_DEVELOPMENT_TEAM}",
      "minimumSystemVersion": "15.0"
    },
    "android": {
      "minSdkVersion": 24
    }
  },
  "app": {
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval' https://elizacloud.ai https://*.elizacloud.ai; connect-src * data: blob:; img-src * data: blob:; font-src * data:; frame-src https://auth.privy.io https://*.walletconnect.com https://*.walletconnect.org"
    },
    "windows": [
      {
        "title": "Eliza Cloud",
        "width": 1200,
        "height": 800,
        "minWidth": 375,
        "minHeight": 667,
        "resizable": true
      }
    ]
  },
  "plugins": {
    "deep-link": {
      "mobile": [
        {
          "schemes": ["elizacloud"],
          "host": "elizacloud.ai"
        }
      ],
      "desktop": {
        "schemes": ["elizacloud"]
      }
    }
  }
}
