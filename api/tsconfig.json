{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023", "WebWorker"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "types": ["@cloudflare/workers-types"],
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "strict": true,
    "resolveJsonModule": true,
    "paths": {
      "@/api-lib/*": ["./src/lib/*"],
      "@/api-queue/*": ["./src/queue/*"],
      "@/lib/*": ["../packages/lib/*"],
      "@/db/*": ["../packages/db/*"],
      "@/types/*": ["../packages/types/*"],
      "@/*": ["../*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "**/route.ts"
  ],
  "exclude": [
    "node_modules",
    "../node_modules"
  ]
}
