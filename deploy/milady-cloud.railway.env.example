# Milady Cloud Railway production environment
#
# Copy these keys into the Railway service that deploys this repo at:
#   https://cloud.milady.ai
#
# Leave optional blocks unset if you are not enabling those features on day 1.
# However, the managed "Milady Cloud" provisioning flow requires the AWS/ECS
# and JWT bootstrap block below.

# Core URLs
NEXT_PUBLIC_APP_URL=https://cloud.milady.ai
NEXT_PUBLIC_API_URL=https://cloud.milady.ai
ELIZA_CLOUD_URL=https://cloud.milady.ai
NEXT_PUBLIC_MILADY_APP_URL=https://app.milady.ai
ELIZA_CLOUD_AGENT_BASE_DOMAIN=containers.cloud.milady.ai

# Core platform
DATABASE_URL=postgresql://user:password@host:5432/milady_cloud?sslmode=require
REDIS_URL=redis://default:password@host:6379
KV_URL=redis://default:password@host:6379
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
CRON_SECRET=replace_with_a_64_char_random_secret

# Auth (Privy)
NEXT_PUBLIC_PRIVY_APP_ID=cm_replace_me
NEXT_PUBLIC_PRIVY_CLIENT_ID=client-replace-me
PRIVY_APP_SECRET=replace_with_privy_app_secret
PRIVY_WEBHOOK_SECRET=replace_with_privy_webhook_secret

# AI providers (set at least one)
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# Analytics / email
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@cloud.milady.ai
SMTP_HOST=
SMTP_PORT=
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@cloud.milady.ai

# Managed app domain policy
# Set this if hosted apps created from Milady Cloud should live on a Milady subdomain.
APP_DOMAIN=apps.cloud.milady.ai
GITHUB_ORG_NAME=milady-cloud-apps
GITHUB_TEMPLATE_REPO=milady-cloud-apps/cloud-apps-template
GIT_ACCESS_TOKEN=
GITHUB_APP_TOKEN=
GIT_COMMIT_AUTHOR_NAME=Milady Cloud Bot
GIT_COMMIT_AUTHOR_EMAIL=bot@cloud.milady.ai
VERCEL_TOKEN=
VERCEL_TEAM_ID=

# Managed Milady Cloud provisioning (required for create/provision container flow)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
ACM_CERTIFICATE_ARN=
AWS_VPC_ID=
AWS_SUBNET_IDS=
AWS_SECURITY_GROUP_IDS=
ECS_CLUSTER_NAME=
ECS_EXECUTION_ROLE_ARN=
ECS_TASK_ROLE_ARN=
ECS_SHARED_ALB_ARN=
ECS_SHARED_LISTENER_ARN=
GATEWAY_BOOTSTRAP_SECRET=replace_with_random_secret
JWT_SIGNING_PRIVATE_KEY=base64_pkcs8_private_key
JWT_SIGNING_PUBLIC_KEY=base64_spki_public_key
JWT_SIGNING_KEY_ID=primary

# Media / billing / chain data
BLOB_READ_WRITE_TOKEN=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SMALL_PACK_PRICE_ID=
STRIPE_SMALL_PACK_PRODUCT_ID=
STRIPE_MEDIUM_PACK_PRICE_ID=
STRIPE_MEDIUM_PACK_PRODUCT_ID=
STRIPE_LARGE_PACK_PRICE_ID=
STRIPE_LARGE_PACK_PRODUCT_ID=
ELEVENLABS_API_KEY=
FAL_KEY=
ALCHEMY_API_KEY=
HELIUS_API_KEY=
BIRDEYE_API_KEY=

# Optional crypto / payouts / support
OXAPAY_MERCHANT_API_KEY=
OXAPAY_CALLBACK_URL=https://cloud.milady.ai/api/crypto/webhook
OXAPAY_RETURN_URL=https://cloud.milady.ai/payment/success
EVM_PAYOUT_PRIVATE_KEY=
EVM_PAYOUT_WALLET_ADDRESS=
SOLANA_PAYOUT_PRIVATE_KEY=
SOLANA_PAYOUT_WALLET_ADDRESS=
SOLANA_RPC_URL=
