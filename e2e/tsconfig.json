{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "declarationMap": false,
    "noEmit": true,
    "types": ["node"],
    "paths": {
      "@/*": ["../"]
    }
  },
  "include": ["./**/*.ts"],
  "exclude": ["node_modules", ".cache-synpress", "test-results", "test-reports"]
}




