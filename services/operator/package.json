{
  "name": "@elizaos/operator",
  "version": "0.0.1",
  "description": "ElizaOS Server Operator",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "pepr": {
    "uuid": "eliza-operator",
    "onError": "reject",
    "webhookTimeout": 10,
    "customLabels": {
      "namespace": {
        "pepr.dev": ""
      }
    },
    "alwaysIgnore": {
      "namespaces": []
    },
    "admission": {
      "alwaysIgnore": {
        "namespaces": []
      }
    },
    "watch": {
      "alwaysIgnore": {
        "namespaces": []
      }
    },
    "includedFiles": [],
    "env": {}
  },
  "scripts": {
    "build": "npx pepr build",
    "dev": "npx pepr dev",
    "deploy:local": "npx pepr build && ./scripts/deploy-local.sh"
  },
  "dependencies": {
    "ioredis": "^5.9.3",
    "pepr": "^1.1.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "5.8.3"
  }
}
